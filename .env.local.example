# ============================================================
# REQUIRED — the app won't start without these.
# ============================================================

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key. Bypasses RLS; used only by server-side
# routes (the webhook, automation engine, and the public API key
# auth path — see docs/public-api.md). Keep this secret — never
# paste it into client code.
#
# Note: the public API (/api/v1) needs no new env var. API keys are
# created in the dashboard (Settings → API keys) and stored hashed
# in the database; this service-role key is what lets the auth path
# look a presented key up without a user session.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp token encryption (64 hex chars = 32 bytes, AES-256-GCM).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value orphans every token encrypted under the previous
# key — users have to re-save their WhatsApp settings to reconnect.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Meta App Secret (Meta for Developers → App Settings → Basic).
# Verifies the HMAC-SHA256 signature on every inbound webhook POST.
# Required — without it the webhook rejects every request.
META_APP_SECRET=your-meta-app-secret

# Platform-wide WhatsApp webhook verify token — set this to the SAME
# value entered in Meta for Developers → WhatsApp → Configuración →
# Webhook → "Token de verificación" (one-time setup, shared by every
# client account connected via Embedded Signup — see
# lib/cron/verify-secret.ts's timing-safe comparison used here).
# Generate any long random string: openssl rand -hex 32
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ------------------------------------------------------------------
# Zuhma Med CRM platform subscription (legacy, unused in this fork) (Stripe) — what a clinic pays
# Zuhma Med CRM itself, NOT the quotes/invoices/payments module the
# clinic uses to bill ITS OWN patients (that module has no Stripe
# involvement at all).
# ------------------------------------------------------------------
# Secret key from the Stripe Dashboard → Developers → API keys. Use
# a test-mode key (sk_test_...) until you're ready to go live.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Signing secret for the webhook endpoint (Stripe Dashboard →
# Developers → Webhooks → add endpoint pointing at
# https://<your-domain>/api/webhooks/stripe → reveal signing secret).
# Without this, POST /api/webhooks/stripe rejects every event.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Price IDs from Stripe Dashboard → Products. Every plan now bills as
# base price (first seat) + a per-extra-seat price, standalone
# included — STANDALONE_BASE is the $49/mo "Zuhma Med CRM" first-seat (legacy, unused)
# price, STANDALONE_SEAT is its $25/mo extra-seat price. The two
# Zentro Salud bundles share one seat "add-on" price used once an
# account exceeds its included seats. See
# src/lib/billing-platform/plans.ts for how these map to PLAN_CONFIG.
STRIPE_PRICE_STANDALONE_BASE=price_your-standalone-base-price-id
STRIPE_PRICE_STANDALONE_SEAT=price_your-standalone-seat-price-id
STRIPE_PRICE_ZENTRO_SALUD_STARTER=price_your-starter-bundle-price-id
STRIPE_PRICE_ZENTRO_SALUD_PRO=price_your-pro-bundle-price-id
STRIPE_PRICE_SEAT_ADDON=price_your-seat-addon-price-id

# Shared secret protecting GET /api/billing-platform/cron (marks
# expired trials read-only). Generate any long random string:
#   openssl rand -hex 32
BILLING_CRON_SECRET=generate-a-long-random-string

# Shared secret protecting POST /api/internal/webhooks/new-account —
# set the SAME value as the "x-webhook-secret" HTTP header on the
# Supabase Database Webhook (Dashboard → Database → Webhooks → new
# hook on `accounts` INSERT). Generate any long random string:
#   openssl rand -hex 32
NEW_ACCOUNT_WEBHOOK_SECRET=generate-a-long-random-string

# Direct Resend integration — for email THIS app sends itself
# (documents to patients, internal team alerts), independent of
# Supabase Auth's own SMTP-relay emails (signup/recovery/magic-link,
# configured separately in Supabase's dashboard, or via the Auth Send
# Email Hook — see docs/auth-email-hook.md). Get the API key from
# resend.com → API Keys. RESEND_FROM_EMAIL must be an address on a
# domain you've verified in Resend (Domains → your domain) — sends
# from an unverified domain are rejected.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Zuhma Med CRM <no-reply@zuhma.com>

# Error monitoring (Sentry). Everything here is optional — the app
# runs identically with none of these set, just without alerting.
# Create a free Next.js project at sentry.io to get a DSN; same value
# for both (NEXT_PUBLIC_ is inlined into the browser bundle at build
# time, so it needs its own copy of the var). ORG/PROJECT/AUTH_TOKEN
# are only used at build time to upload source maps for readable
# stack traces — get the auth token from Settings → Auth Tokens.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================================
# RECOMMENDED — safe defaults exist but you'll want to set these.
# ============================================================

# Canonical public URL of this deployment (scheme + host, no trailing
# slash). Used for the sitemap and OG images. Routes that need a
# self-referential URL (invite links from /api/account/invitations,
# any future email-bound link) derive the origin from the request
# itself, so this variable is *only* needed when the request-derived
# origin would be wrong — e.g. when generating links from a cron job
# or a background worker that has no incoming request.
NEXT_PUBLIC_SITE_URL=https://crm.example.com

# Default language locale (e.g. en)
NEXT_PUBLIC_APP_LOCALE=en

# ============================================================
# OPTIONAL — only needed if you use the feature.
# ============================================================

# Defense-in-depth allow-list for the hostnames that
# /api/account/invitations is willing to publish in invite URLs.
# Comma-separated, no scheme, no port (just hostnames).
#
# Why this exists: when NEXT_PUBLIC_SITE_URL is unset, invite URLs
# are derived from the incoming request's `Host` / `X-Forwarded-
# Host` header. On a typical proxied deploy the proxy sets these
# to your canonical hostname and they're trustworthy. On a *bare*
# deployment exposed to the public internet, an attacker could
# POST to the API directly with a spoofed `Host: phishing.example`
# and receive an invite URL pointing at their site.
#
# When this var is set, hostnames not on the list are rejected
# (the request falls through to the wacrm.tech fallback with a
# console.warn). When unset, behavior is unchanged from earlier
# versions — the request-derived host is trusted.
#
# Most operators don't need this: setting NEXT_PUBLIC_SITE_URL to
# your canonical URL already pins invite links there. This is for
# operators who want belt-and-braces or run multi-tenant setups
# where one app instance serves several hostnames.
#
# Example:
#   ALLOWED_INVITE_HOSTS=crm.example.com,crm-staging.example.com

# Shared secret protecting GET /api/automations/cron. Required if you
# use Wait steps in automations (a scheduled pinger drains pending
# executions). Generate any long random string:
#   openssl rand -hex 32
# See docs/automations-and-cron.md.
# AUTOMATION_CRON_SECRET=generate-a-long-random-string

# ------------------------------------------------------------------
# Google Calendar sync (optional) — one-way, Zuhma Med CRM → Google.
# ------------------------------------------------------------------
# OAuth 2.0 Web application credentials from Google Cloud Console
# (APIs & Services → Credentials). Authorized redirect URI must be
# exactly {NEXT_PUBLIC_SITE_URL}/api/google-calendar/callback. Without
# these, "Conectar" on /agenda/mine fails — no other feature depends
# on them.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# ------------------------------------------------------------------
# Cal.com inbound bookings (optional, prepared — no in-app UI yet)
# ------------------------------------------------------------------
# No env var needed — POST /api/integrations/cal-com/webhook/[accountId]
# verifies each request against that account's own
# accounts.cal_com_webhook_secret (migration 054, server-generated,
# no app config). See that route's own comment for manual per-clinic
# setup steps.

# Meta App ID (Meta for Developers → App Settings → Basic). Required to
# create/edit message templates with an IMAGE header: Meta only accepts a
# Resumable-Upload media handle (not a plain URL) as the header sample, and
# that upload is app-scoped. Without it, image-header template submission
# returns a clear error; text/body-only templates are unaffected. Pair
# with META_APP_SECRET. Also used server-side by the WhatsApp Embedded
# Signup code exchange (POST /api/whatsapp/embedded-signup) — same App ID.
META_APP_ID=your-meta-app-id

# WhatsApp Embedded Signup (Settings → WhatsApp → "Conectar con Meta"),
# an alternative to manually pasting a System User token. Optional —
# the button just doesn't render without these. NEXT_PUBLIC_META_APP_ID
# is the SAME value as META_APP_ID above, duplicated because only
# NEXT_PUBLIC_-prefixed vars get inlined into the browser bundle.
# NEXT_PUBLIC_META_WA_SIGNUP_CONFIG_ID is a "Login Configuration" you
# create in Meta App Dashboard → Facebook Login for Business →
# Configurations, scoped to the WhatsApp Embedded Signup product — see
# the setup doc for the exact steps.
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_WA_SIGNUP_CONFIG_ID=your-embedded-signup-login-config-id

# Meta Ads Embedded Connect (Settings → Conversiones → "Conectar Meta
# Ads"), the direct-CAPI alternative to manually pasting a pixel ID +
# access token. Same mechanism as WhatsApp Embedded Signup above, but
# needs its OWN Login Configuration (Meta App Dashboard → Facebook
# Login for Business → Configurations) requesting ads_management,
# business_management, and read_insights — that combination is what
# lets the backend auto-discover the client's ad account and pixel
# instead of asking them to find and paste those IDs. Optional — the
# button just doesn't render without this config ID.
NEXT_PUBLIC_META_ADS_SIGNUP_CONFIG_ID=your-ads-signup-login-config-id

# When "true", POST /api/whatsapp/templates/submit skips the Meta call
# and stores the row with a synthetic `dry-run-<uuid>` meta_template_id.
# Set this in CI and local development so you can exercise the full
# template UI without a real WABA. Leave unset (or "false") in prod.
# WHATSAPP_TEMPLATES_DRY_RUN=true

# ------------------------------------------------------------------
# AI reply assistant (optional)
# ------------------------------------------------------------------
# The AI assistant is bring-your-own-key: each account pastes its own
# OpenAI or Anthropic key under Settings → AI Assistant. The key is
# stored AES-256-GCM-encrypted with ENCRYPTION_KEY (above) — there is
# NO global provider key env var, and nothing here is required for the
# feature to work. The two vars below only tune behaviour.
#
# The AI knowledge base (migration 030) uses Postgres full-text search
# out of the box. Optional semantic search needs the `pgvector`
# extension — migration 030 runs `CREATE EXTENSION IF NOT EXISTS vector`
# (Supabase has it available) — plus a per-account embeddings key set in
# Settings → AI Assistant. Still no env var required.

# Per-call timeout for provider requests, in milliseconds. Default 30000.
# AI_REQUEST_TIMEOUT_MS=30000

# How many recent text messages of a conversation to send the model as
# context (draft + auto-reply). Default 20.
# AI_CONTEXT_MESSAGE_LIMIT=20

# Login CAPTCHA (optional)
# ------------------------------------------------------------------
# Cloudflare Turnstile on the login form. Create a widget at
# https://dash.cloudflare.com/?to=/:account/turnstile — pick "Managed"
# mode, add your production domain. Both vars are optional: leaving
# them unset skips the CAPTCHA entirely (widget doesn't render,
# server-side verification is skipped) so local dev works without a
# Cloudflare account. Set both in production for real protection.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key
